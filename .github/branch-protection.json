{
  "rule": {
    "requires_code_owner_reviews": true,
    "required_approving_review_count": 1,
    "dismisses_stale_reviews": true,
    "requires_commit_signatures": false,
    "restricts_pushes": false,
    "requires_status_checks": true,
    "required_status_checks": [
      {
        "context": "test",
        "app_id": 0
      },
      {
        "context": "lint",
        "app_id": 0
      },
      {
        "context": "build",
        "app_id": 0
      }
    ],
    "strict": true
  }
}
